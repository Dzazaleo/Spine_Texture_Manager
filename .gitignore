# Dependencies
node_modules/

# Build output
dist/
coverage/

# electron-vite bundle output
out/

# electron-builder release output (defensive — default is dist/ which is already ignored)
release/

# TypeScript project-references incremental build info (composite: true emits these)
*.tsbuildinfo

# User's Spine editor source files — NOT part of the app
temp/

# Licensed/third-party rigs used locally for validation only — not redistributable
fixtures/Jokerman/
fixtures/Girl/
fixtures/images/
fixtures/Chicken/
fixtures/3Queens/
fixtures/CHJ/
fixtures/MON_FILES/
# fixtures/spine_stripWS/ is NOT gitignored — minimal Strip-Whitespace regression
# fixture (40K) committed in-repo per fixtures/ convention; locks the late v1.3.1
# tester-fix commit 1b5414c. Two test files (loader-strip-whitespace.spec.ts +
# image-worker.strip-whitespace.spec.ts) read from it without skip guards.
# Joker assets (TOPSCREEN_ANIMATION_JOKER.*) — proprietary, kept local only.
# Note: a handful of test specs read from this fixture (loader, analyzer,
# sampler-skin-defined-unbound-attachment, atlas-preview) and will fail on
# fresh clones / CI until ported to a SIMPLE_PROJECT-equivalent fixture.
fixtures/SAMPLER_ALPHA_ZERO/
# Spine 4.3-beta exports of the same proprietary Joker rigs (SEED-003 reproduction fixtures).
fixtures/test_4.3/
# v1.4 Phase 35 multi-skin fixture (JOKERMAN proprietary, 358M). Phase 35 export.spec.ts
# uses it.skipIf via TEST_4_FIXTURE_PRESENT so absence doesn't break tests/CI.
fixtures/SKINS/
# v1.4 Phase 35 CR-01 follow-up fixture (Spine 4.2 non-essential-disabled mesh
# export). Used by tests/core/export.spec.ts Test 5 via it.skipIf via
# TEST_5_FIXTURE_PRESENT — absent on fresh clones, present locally.
fixtures/SIMPLE_PROJECT_NO_ATLAS_MESH_NON_ESSENTIAL/
# v1.4 Phase 33 rotated-region exploration; not referenced by any test/src.
fixtures/Rotated/
# Root-level proprietary Spine project (Joker TOPSCREEN). Same convention as temp/
# but checked-in directly by the editor; keep local-only.
/Rotation_Complex/
# Ad-hoc migration debug scripts — mirrors the scripts/probe-*.ts pattern.
scripts/migrate-*.mjs
# Scratch exploratory specs — `_exploratory-` prefix is the convention for
# investigation/sketch tests that aren't meant to ship.
tests/**/_exploratory-*.spec.tsx
tests/**/_exploratory-*.spec.ts

# OS cruft
.DS_Store

# sed/editor backup files (matches .bak, .bak2, .bak3, …)
*.bak*

# Logs
*.log
npm-debug.log*

# Phase 2 CLI byte-for-byte golden + sibling diff artifacts
# (handoff between Plan 02-01 Task 3 and Plan 02-03; removed by 02-03 final cleanup)
fixtures/SIMPLE_PROJECT/.cli-*.txt

# Debug probe scripts — ad-hoc sampler/analyzer investigations, not part of the app
scripts/probe-*.ts
scripts/diagnose-*.ts
/probe-*.mjs
/probe-*.ts

# Claude Code local config + agent worktrees (per-machine, not for remote)
.claude/

# Per-machine agent worktree state
.claire/

# Vitest scratch trace dirs (ad-hoc investigation specs, not production tests)
tests/_trace_tmp/

# GSD ephemeral checkpoint state (regenerated each discuss-phase session)
.planning/**/*-DISCUSS-CHECKPOINT.json

# Playwright MCP scratch dir
.playwright-mcp/

# Manual UAT save artifacts in fixtures
fixtures/SIMPLE_PROJECT/temp.stmproj
