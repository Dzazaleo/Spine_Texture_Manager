{
  "name": "spine-texture-manager",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "main": "./out/main/index.cjs",
  "description": "Desktop app that computes per-attachment peak render scale for Spine 4.2+ skeletons.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "cli": "tsx scripts/cli.ts",
    "fixture:atlas-source-drift": "node scripts/fixture-atlas-source-drift.mjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "build:mac": "electron-vite build && electron-builder --mac --publish never && node scripts/emit-latest-yml.mjs --platform=mac",
    "build:win": "electron-vite build && electron-builder --win --publish never && node scripts/emit-latest-yml.mjs --platform=win",
    "build:linux": "electron-vite build && electron-builder --linux --publish never && node scripts/emit-latest-yml.mjs --platform=linux",
    "build:dry": "electron-vite build && electron-builder --mac dmg --dir",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "@esotericsoftware/spine-core": "^4.2.0",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tanstack/react-virtual": "^3.13.24",
    "electron-updater": "^6.8.3",
    "maxrects-packer": "^2.7.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "clsx": "^2.1.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.0.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
