{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.ts",
    "vitest.config.ts",
    "src/main/**/*.ts",
    "src/preload/index.ts",
    "src/shared/**/*.ts",
    "src/core/**/*.ts",
    "src/renderer/src/lib/**/*.ts",
    // Phase 52 (D-05 / IN-01): the renderer-local PURE token helper
    // variant-scale-derive.ts (zero imports, ES2022-clean — no React/DOM) is
    // imported by tests/main/variant-token-equivalence.spec.ts to lock the
    // cross-boundary tokenFor ≡ formatScaleToken mirror. Because this is a
    // `composite` project, an imported file must be EXPLICITLY listed (not just
    // pulled in via the import edge) or tsc raises TS6307. Listing only the
    // single-level *.ts here pulls in exactly that one pure helper; the sibling
    // React/DOM modal *.tsx files do NOT match (and stay out of this no-DOM
    // node program, lib: ES2022 / types: node). Mirrors the existing
    // src/renderer/src/lib/**/*.ts include for the same Layer-3 reason.
    "src/renderer/src/modals/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "out",
    "release",
    "temp",
    "coverage",
    // Renderer-integration spec: statically imports the React router
    // (AnimationPlayerModalRouter.tsx → AnimationPlayerModal*.tsx → useFocusTrap.ts),
    // all DOM code. This no-DOM node program (lib: ES2022, types: node) cannot
    // typecheck it. It is a .ts file so it falls into the tests/**/*.ts glob;
    // every other renderer test is .spec.tsx and already outside both tsc
    // programs (vitest-only). Keep this one consistent with that convention.
    "tests/runtime/dual-viewer-routing.spec.ts",
    // Phase 50 (SCALEUI-01) renderer two-way scale↔dimension helper spec:
    // a .ts file under tests/renderer/ that imports the renderer-local module
    // src/renderer/src/modals/variant-scale-derive.ts, which is not in this
    // node program's include. Same case as dual-viewer-routing above — a .ts
    // renderer test caught by the tests/**/*.ts glob. Keep it vitest-only,
    // consistent with the .spec.tsx renderer-test convention (its component
    // sibling variant-twoway.spec.tsx is already outside both tsc programs).
    "tests/renderer/variant-twoway.spec.ts",
    // v1.0-era ad-hoc debug entrypoints (scripts/probe-*.ts,
    // diagnose-cam-physics.ts). Not product code, not tests, not run in CI,
    // not imported by anything. They were written against the old spine-ts
    // API and have drifted hard against the 4.3 runtime types. Scratch
    // tooling is intentionally not type-gated; cli.ts and
    // register-esm-adapter-resolver.ts (real scripts) stay checked.
    "scripts/probe-*.ts",
    "scripts/diagnose-cam-physics.ts",
    // Gitignored local scratch (vitest --trace scratchpad). Never in a
    // fresh clone so CI never sees it; this guard keeps local
    // typecheck:node == CI instead of reddening on throwaway trace files.
    "tests/_trace_tmp/**"
  ],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"]
  }
}
