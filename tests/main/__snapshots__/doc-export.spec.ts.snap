    <span class="chip"><svg viewBox="0 0 20 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none" width="16" height="16"><rect x="2" y="3" width="16" height="14" rx="1"/><circle cx="7" cy="8" r="1.5"/><path d="M2 14 l4 -4 4 3 4 -5 4 4 v5"/></svg>174 Images Utilized</span>
    <span class="chip"><svg viewBox="0 0 20 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none" width="16" height="16"><rect x="3" y="3" width="14" height="14" rx="2"/><path d="M9 7 l4 3 -4 3 z"/></svg>0 Animations Configured</span>
    <span class="chip"><svg viewBox="0 0 20 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none" width="16" height="16"><path d="M11 2 L4 11 h5 l-2 7 7 -9 h-5 z"/></svg>170 Optimized Assets</span>
    <span class="chip"><svg viewBox="0 0 20 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none" width="16" height="16"><path d="M2 5 l5 -2 6 2 5 -2 v12 l-5 2 -6 -2 -5 2 z"/><path d="M7 3 v14 M13 5 v14"/></svg>4 Atlas Pages (2048px)</span>
  </div><div class="row"><div class="card">
    <div class="card-header"><span><svg viewBox="0 0 20 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none" width="16" height="16"><path d="M10 3 L4 5 v5 c0 4 3 6 6 7 3 -1 6 -3 6 -7 V5 z"/></svg></span><span>Optimization Config</span></div>
    <div class="config-value">0%</div>
    <div class="config-label">Safety Buffer</div>
    <div class="config-value" style="margin-top:16px;">91.7%</div>
    <div class="config-label">Space Savings</div>
    <div class="config-sublabel">Estimated Reduction</div>
  </div><div class="card">
    <div class="card-header notes"><span><svg viewBox="0 0 20 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none" width="16" height="16"><path d="M3 4 h14 v9 h-7 l-4 3 v-3 H3 z"/></svg></span><span>General Notes</span></div>
    <pre class="notes-pre"></pre>
  </div></div><div class="card">
      <div class="card-header tracks"><span><svg viewBox="0 0 20 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none" width="16" height="16"><circle cx="10" cy="10" r="7"/><path d="M10 6 v4 l3 2"/></svg></span><span>Animation Tracks</span></div>
      <p class="empty-state">No animation tracks configured.</p>
    </div><div class="row"><div class="card">
      <div class="card-header bones"><span><svg viewBox="0 0 20 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none" width="16" height="16"><path d="M5 8 a2 2 0 0 1 2 -2 h6 a2 2 0 0 1 2 2 v4 a2 2 0 0 1 -2 2 h-6 a2 2 0 0 1 -2 -2 z"/></svg></span><span>Control Bones</span></div>
